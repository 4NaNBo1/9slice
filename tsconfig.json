{
  "compilerOptions": {
    "target": "ES2021",
    "lib": ["ES2021", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["@figma/plugin-typings", "@mastergo/plugin-typings"]
  },
  "include": ["src/**/*.ts", "tests/**/*.ts"]
}
